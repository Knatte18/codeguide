{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/nav_init_session.py"}]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/check_docs_on_prompt.py"}]
      },
      {
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/nav_track_subagent_inject.py"}]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/nav_track_read.py"}]
      },
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/nav_track_search.py"}]
      },
      {
        "matcher": "Agent",
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/nav_track_task.py"}]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/update_docs_after_edit.py"}]
      }
    ],
    "Stop": [
      {
        "hooks": [{"type": "command", "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/nav_stop.py"}]
      }
    ]
  }
}
